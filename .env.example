#容器配置
NUXT_HOST=0.0.0.0
NUXT_PORT=3000
#后端接口地址
VITE_API_URL=https://classics-api.example.com/
# Casdoor 服务端地址
CASDOOR_SERVER_URL=https://door.casdoor.com
# 组织与应用
CASDOOR_ORG_NAME=YourOrgName
CASDOOR_APP_NAME=YourAppName
# OAuth2 客户端凭证
CASDOOR_CLIENT_ID=YourClientId
CASDOOR_CLIENT_SECRET=YourClientSecret
# JWT 公钥（PEM 格式，供后端验证用）
CASDOOR_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANB...\n-----END PUBLIC KEY-----"
# 回调路径（相对于站点根）
CASDOOR_REDIRECT_PATH=/callback
